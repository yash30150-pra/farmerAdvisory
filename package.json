{
  "name": "farmer-advisory",
  "version": "1.0.0",
  "description": "Farmer Advisory Mobile App - React Native Android Application",
  "author": "Farmer Advisory Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "npx expo start",
    "web": "npx expo start --web",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "eject": "npx expo eject",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "clean": "rm -rf node_modules && npm install",
    "reset-cache": "expo start --reset-cache",
    "dev": "expo start --clear",
    "prebuild": "expo prebuild --clean",
    "build-android": "eas build --platform android",
    "build-ios": "eas build --platform ios",
    "build-all": "eas build --platform all",
    "logs": "expo logs",
    "tunnel": "expo start --tunnel",
    "lan": "expo start --lan"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.76.0",
    "expo": "^54.0.0",
    "expo-location": "~17.0.0",
    "expo-device": "~6.0.0",
    "@react-navigation/native": "^6.0.0",
    "@react-navigation/bottom-tabs": "^6.0.0",
    "react-native-screens": "~3.30.0",
    "react-native-safe-area-context": "4.7.2",
    "axios": "^1.6.0",
    "@react-native-async-storage/async-storage": "1.21.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@react-native/babel-preset": "^0.76.0",
    "@react-native/eslint-config": "^0.76.0",
    "@react-native/metro-config": "^0.76.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.2",
    "babel-jest": "^29.7.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-transformer": "^0.76.0",
    "prettier": "^3.1.1",
    "react-test-renderer": "18.2.0",
    "concurrently": "^8.2.2"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ]
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "react-native",
    "android",
    "farmer-advisory",
    "agriculture",
    "weather",
    "crop-recommendations",
  
    "market-prices",
    "chatbot"
  ]
}
